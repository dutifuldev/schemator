{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dutifuldev.github.io/schemator/schemas/field-review.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "model",
    "fieldPath",
    "decision",
    "finalName",
    "finalType",
    "required",
    "rationale",
    "alternatives",
    "simplestChoice",
    "confidence",
    "questions"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "model": { "type": "string", "minLength": 1 },
    "fieldPath": { "type": "string", "minLength": 1 },
    "decision": {
      "enum": ["keep", "rename", "merge", "derive", "move", "defer", "remove", "opaque"]
    },
    "finalName": { "type": "string", "minLength": 1 },
    "finalPath": { "type": "string", "minLength": 1 },
    "finalType": { "type": "string" },
    "required": { "type": "boolean" },
    "rationale": { "type": "string", "minLength": 1 },
    "alternatives": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "simplestChoice": { "type": "string", "minLength": 1 },
    "confidence": { "enum": ["low", "medium", "high"] },
    "questions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ownerBoundary": { "type": "string" }
  }
}
