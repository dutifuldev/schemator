{
  "name": "@dutifuldev/schemator",
  "version": "0.1.0",
  "description": "Schema and data-model review CLI for agents and maintainers.",
  "license": "MIT",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dutifuldev/schemator.git"
  },
  "bugs": {
    "url": "https://github.com/dutifuldev/schemator/issues"
  },
  "homepage": "https://github.com/dutifuldev/schemator#readme",
  "keywords": [
    "schema",
    "data-model",
    "cli",
    "agents",
    "review"
  ],
  "engines": {
    "node": ">=22.13.0"
  },
  "bin": {
    "schemator": "dist/cli.js"
  },
  "files": [
    "dist/**",
    "schemas/**",
    "skills/**",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "npm run typecheck && npm test && npm run build",
    "dev": "tsx src/cli.ts",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^14.0.3",
    "skillflag": "^0.2.0",
    "typescript": "^5.9.3",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.0",
    "tsx": "^4.22.0",
    "vitest": "^4.1.9"
  }
}
